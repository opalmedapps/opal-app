# restrict dependency releases to be at least 7 days old
# see: https://socket.dev/blog/npm-introduces-minimumreleaseage-and-bulk-oidc-configuration#New-minimumReleaseAge-Setting
min-release-age=7 # days
ignore-scripts=true
